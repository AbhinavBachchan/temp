#include<stdio.h>

struct employee

{

    int no,age,salary;

    long phonenumber;

    char name[25];

}emp[100];

void main()

{

    int i,n;

    printf("Enter the no of employees\n");

    scanf("%d",&n);

    printf("Enter employee info as no , name , age ,phone number, salary\n");

    for(i=0;i<n;i++)

    {

        scanf("%d %s %d %d %d",&emp[i].no,&emp[i].name,&emp[i].age,&emp[i].phonenumber,&emp[i].salary);

    }

    printf("\nEMP_NO\tEMP_NAME\tEMP_AGE\t\tEMP_PHONE NUMBER\t\tEMP_SAL\n");

    for(i=0;i<n;i++)

    {

        printf("%d\t\t%s\t\t%d\t\t%d\t\t%d\n",emp[i].no,emp[i].name,emp[i].age,emp[i].phonenumber,emp[i].salary);

    }

}
