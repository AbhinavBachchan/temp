#include<stdio.h>
struct employee{
	int empno;
	char empname[20];
	long phone;
	int age;
	long salary;
};
void input(struct employee e[20]){
	for(int j=1;j<=20;j++){
	
    printf("\nName:");          
	gets(e[j].empname);
    printf("\nEmployee No:");   
	scanf("%d",&e[j].empno);
    printf("Salary:");      
	scanf("%d",&e[j].salary);
    printf("\nAge:");           
	scanf("%d",&e[j].age);
    printf("\nPhone no:");     
	scanf("%d",&e[j].phone);}
    }
void output(struct employee e[20]){
	for(int i=1;i<=1;i++){
	printf("%c /t %d /t %d /t %d /t %d",e[i].empname,e[i].empno,e[i].salary,e[i].age,e[i].phone);}
}

int main(){
	struct employee e[20];
	printf("/nEnter the details of 20 employees:\n ");
	input(e);
	printf("\nDETAILS ENTERED ARE AS FOLLOWS: ");
	printf("\nNAME /t EMPLOYEE NO /t SALARY /t AGE /t PHONE NO");
	output(e);
	printf("\nTHANK YOU");
	return 0;
}
